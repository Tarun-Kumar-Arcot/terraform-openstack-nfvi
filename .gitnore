# Terraform state — never commit these
*.tfstate
*.tfstate.backup
*.tfstate.*.backup

# Saved plan files
tfplan
*.tfplan

# Terraform working directory
.terraform/

# Lock file — commit this if you want reproducible provider versions
# .terraform.lock.hcl

# Crash logs
crash.log
crash.*.log

# Sensitive variable files
*.tfvars
*.tfvars.json
!example.tfvars

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
